{
    "consumes": [
        "application/json"
    ],
    "produces": [
        "application/json"
    ],
    "schemes": [
        "http",
        "https"
    ],
    "swagger": "2.0",
    "info": {
        "description": "Watchtower HTTP API for container update management, metrics, and health probes.",
        "title": "Watchtower HTTP API",
        "termsOfService": "https://github.com/nicholas-fedor/watchtower",
        "contact": {
            "name": "Nicholas Fedor",
            "url": "https://github.com/nicholas-fedor/watchtower"
        },
        "license": {
            "name": "MIT",
            "url": "https://opensource.org/licenses/MIT"
        },
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/livez": {
            "get": {
                "description": "Always returns 200 OK when the server is running.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "health"
                ],
                "summary": "Liveness probe",
                "responses": {
                    "200": {
                        "description": "Server is alive",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/readyz": {
            "get": {
                "description": "Verifies Docker client connectivity. Returns 200 OK if connected, 503 otherwise.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "health"
                ],
                "summary": "Readiness probe",
                "responses": {
                    "200": {
                        "description": "Server is ready",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "503": {
                        "description": "Docker client not connected",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/startupz": {
            "get": {
                "description": "Always returns 200 OK once the server has started.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "health"
                ],
                "summary": "Startup probe",
                "responses": {
                    "200": {
                        "description": "Server has started",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/v1/check": {
            "post": {
                "description": "Checks each watched container for available image updates without pulling or restarting. Returns per-container update availability.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "check"
                ],
                "summary": "Check for available container updates",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Filter by image name (comma-separated, repeatable)",
                        "name": "image",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter by container name (comma-separated, repeatable)",
                        "name": "container",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Container update availability results",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Failed to check for updates",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/v1/config": {
            "get": {
                "description": "Returns the active Watchtower configuration settings. Sensitive values (notification URLs, tokens) are redacted.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "config"
                ],
                "summary": "Get current configuration",
                "responses": {
                    "200": {
                        "description": "Current configuration",
                        "schema": {
                            "$ref": "#/definitions/config.ConfigData"
                        }
                    },
                    "500": {
                        "description": "Failed to get configuration",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/v1/containers": {
            "get": {
                "description": "Returns the current image identity and digest for every watched container. Optionally filter by container name or image name.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "containers"
                ],
                "summary": "List watched container statuses",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Filter by container name (exact match)",
                        "name": "name",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter by image name (exact match)",
                        "name": "image",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Container statuses with count and timestamp",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Failed to list containers",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/v1/containers/details": {
            "get": {
                "description": "Returns detailed information about each watched container, including running state, image identity, and configuration flags. Optionally filter by container name or image name.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "containers"
                ],
                "summary": "Detailed container status",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Filter by container name (exact match)",
                        "name": "name",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter by image name (exact match)",
                        "name": "image",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Container details with count and timestamp",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Failed to get container details",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/v1/events": {
            "get": {
                "description": "Streams Watchtower operational events (scan started/completed, update started/completed/failed) via Server-Sent Events.",
                "produces": [
                    "text/event-stream"
                ],
                "tags": [
                    "events"
                ],
                "summary": "Real-time events stream",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Resume from event ID",
                        "name": "last_event_id",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Event stream",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/v1/history": {
            "get": {
                "description": "Returns historical scan results from the in-memory ring buffer (up to 500 entries). Optionally filter by time range and limit the number of results.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "history"
                ],
                "summary": "Scan history",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Include entries at or after this RFC3339 timestamp",
                        "name": "since",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Include entries at or before this RFC3339 timestamp",
                        "name": "until",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Maximum number of entries to return (default: all)",
                        "name": "limit",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "History entries with count and timestamp",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Invalid query parameter",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/v1/images": {
            "get": {
                "description": "Returns the current image identity and digest for every image tracked by Watchtower. Optionally filter by image name or image ID.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "images"
                ],
                "summary": "List tracked images",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Filter by image name (exact match)",
                        "name": "name",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter by image ID (sha256:...)",
                        "name": "id",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Image statuses with count and timestamp",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Failed to list images",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/v1/metrics": {
            "get": {
                "description": "Returns Watchtower scan metrics in Prometheus exposition format.",
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "metrics"
                ],
                "summary": "Prometheus metrics",
                "responses": {
                    "200": {
                        "description": "Prometheus exposition format metrics",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/v1/status": {
            "get": {
                "description": "Returns the summary of the most recent Watchtower scan, including counts of scanned, updated, failed, restarted, and skipped containers.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "metrics"
                ],
                "summary": "Last scan status",
                "responses": {
                    "200": {
                        "description": "Scan summary with counts and timestamp",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "204": {
                        "description": "No Content"
                    }
                }
            }
        },
        "/v1/update": {
            "post": {
                "description": "Scans watched containers for image updates and applies them. Supports both full scans and targeted updates filtered by image name or container name. Container patterns support Go",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "update"
                ],
                "summary": "Trigger container update scan",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Comma-separated image names to update (repeatable)",
                        "name": "image",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Comma-separated container name patterns to update (repeatable, supports Go regex)",
                        "name": "container",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "When 'true', runs update asynchronously and returns 202 Accepted",
                        "name": "async",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Synchronous update results with summary and timing",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "202": {
                        "description": "Asynchronous update accepted",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "429": {
                        "description": "Another update is already running",
                        "schema": {
                            "type": "string"
                        },
                        "headers": {
                            "Retry-After": {
                                "type": "string",
                                "description": "Seconds to wait before retrying"
                            }
                        }
                    },
                    "503": {
                        "description": "Request cancelled while waiting for lock",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "config.ConfigData": {
            "type": "object",
            "properties": {
                "cleanup": {
                    "description": "Cleanup indicates whether old images are removed after updating.",
                    "type": "boolean"
                },
                "filter_desc": {
                    "description": "FilterDesc is a human-readable description of the applied filter.",
                    "type": "string"
                },
                "include_restarting": {
                    "description": "IncludeRestarting indicates whether restarting containers are included.",
                    "type": "boolean"
                },
                "include_stopped": {
                    "description": "IncludeStopped indicates whether stopped containers are included.",
                    "type": "boolean"
                },
                "label_enable": {
                    "description": "LabelEnable indicates whether label-based enabling is active.",
                    "type": "boolean"
                },
                "lifecycle_hooks": {
                    "description": "LifecycleHooks indicates whether lifecycle hooks are enabled.",
                    "type": "boolean"
                },
                "monitor_only": {
                    "description": "MonitorOnly indicates whether Watchtower is in monitor-only mode.",
                    "type": "boolean"
                },
                "no_pull": {
                    "description": "NoPull indicates whether image pulling is disabled.",
                    "type": "boolean"
                },
                "no_restart": {
                    "description": "NoRestart indicates whether container restarting is disabled.",
                    "type": "boolean"
                },
                "rolling_restart": {
                    "description": "RollingRestart indicates whether containers are restarted one at a time.",
                    "type": "boolean"
                },
                "scope": {
                    "description": "Scope is the monitoring scope.",
                    "type": "string"
                }
            }
        }
    },
    "tags": [
        {
            "description": "Standardized liveness, readiness, and startup probes",
            "name": "health"
        },
        {
            "description": "Trigger and manage container image updates",
            "name": "update"
        },
        {
            "description": "Prometheus metrics and scan status",
            "name": "metrics"
        },
        {
            "description": "Watched container image identity and update availability",
            "name": "containers"
        },
        {
            "description": "Check for available container updates without applying them",
            "name": "check"
        },
        {
            "description": "Historical scan results from the in-memory ring buffer",
            "name": "history"
        },
        {
            "description": "Tracked images with digests and container counts",
            "name": "images"
        },
        {
            "description": "Active Watchtower configuration settings",
            "name": "config"
        },
        {
            "description": "Real-time operational events via Server-Sent Events",
            "name": "events"
        }
    ]
}